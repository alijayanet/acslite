<%- include('../partials/header', { title: 'Daftar ONU - ACS Lite', activePage: 'devices' }) %>

<div class="page-header">
  <div>
    <h1 class="page-title fade-in">Daftar Perangkat ONU</h1>
    <p class="page-subtitle fade-in">Daftar semua ONU/CPE yang terhubung ke server TR-069 ACS</p>
  </div>
  
  <!-- Search form -->
  <form action="/admin/devices" method="GET" class="fade-in" style="display: flex; gap: 10px; min-width: 300px;">
    <div style="position: relative; flex: 1;">
      <input type="text" name="search" class="form-control" placeholder="Cari SN, Brand, atau IP..." value="<%= search %>" style="padding-left: 40px; padding-top: 10px; padding-bottom: 10px;">
      <i class="bi bi-search" style="position: absolute; left: 14px; top: 10px; color: var(--text-secondary);"></i>
    </div>
    <button type="submit" class="btn btn-secondary">Cari</button>
    <% if (search) { %>
      <a href="/admin/devices" class="btn btn-secondary" title="Reset filter"><i class="bi bi-x-lg"></i></a>
    <% } %>
  </form>
</div>

<!-- Device List Table -->
<div class="glass-card fade-in" style="padding: 0;">
  <% if (devices.length === 0) { %>
    <div style="text-align: center; color: var(--text-secondary); padding: 60px 20px;">
      <i class="bi bi-cpu" style="font-size: 48px; color: var(--text-secondary); opacity: 0.5; margin-bottom: 15px; display: block;"></i>
      <h3>Tidak ada perangkat ditemukan</h3>
      <p style="font-size: 14px; margin-top: 5px;">Coba gunakan kata kunci pencarian yang lain atau pastikan perangkat telah melakukan Inform.</p>
    </div>
  <% } else { %>
    <div class="table-container" style="border: none; margin-bottom: 0;">
      <table class="custom-table">
        <thead>
          <tr>
            <th>Status</th>
            <th>Serial Number</th>
            <th>Brand / Model</th>
            <th>IP Address</th>
            <th>Rx Power (dBm)</th>
            <th>PPPoE User</th>
            <th>Inform Terakhir</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% for (const dev of devices) { %>
            <tr>
              <td>
                <% if (dev.online) { %>
                  <span class="badge badge-success"><i class="bi bi-circle-fill" style="font-size: 8px; margin-right: 6px;"></i> Online</span>
                <% } else { %>
                  <span class="badge badge-danger"><i class="bi bi-circle-fill" style="font-size: 8px; margin-right: 6px;"></i> Offline</span>
                <% } %>
              </td>
              <td>
                <strong style="color: var(--text-primary); font-family: monospace; font-size: 14px;"><%= dev.serial_number %></strong>
              </td>
              <td>
                <div><%= dev.manufacturer %></div>
                <div style="font-size: 11px; color: var(--text-secondary);"><%= dev.product_class %></div>
              </td>
              <td>
                <span style="font-family: monospace;"><%= dev.ipAddress %></span>
              </td>
              <td>
                <% 
                  const rxNum = parseFloat(dev.rxPower);
                  let rxClass = '';
                  if (!isNaN(rxNum)) {
                    if (rxNum < -27) rxClass = 'color: var(--color-danger); font-weight: 600;';
                    else if (rxNum < -24) rxClass = 'color: var(--color-warning); font-weight: 600;';
                    else rxClass = 'color: var(--color-success); font-weight: 600;';
                  }
                %>
                <span style="<%= rxClass %>">
                  <%= dev.rxPower %><%= !isNaN(rxNum) ? ' dBm' : '' %>
                </span>
              </td>
              <td>
                <span style="font-family: monospace;"><%= dev.pppoeUser %></span>
              </td>
              <td style="font-size: 13px; color: var(--text-secondary);">
                <%= dev.last_inform %>
              </td>
              <td>
                <a href="/admin/devices/<%= dev.id %>" class="btn btn-secondary btn-sm" style="padding: 6px 12px; font-size: 12px;">
                  Kelola <i class="bi bi-gear-fill"></i>
                </a>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
