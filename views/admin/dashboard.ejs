<%- include('../partials/header', { title: 'Dashboard Admin - ACS Lite', activePage: 'dashboard' }) %>

<div class="page-header">
  <div>
    <h1 class="page-title fade-in">Dashboard Jaringan</h1>
    <p class="page-subtitle fade-in">Status waktu-nyata server TR-069 ACS dan perangkat ONU Anda</p>
  </div>
</div>

<!-- Stats Counters -->
<div class="grid-4 fade-in">
  <div class="glass-card stat-card">
    <div class="stat-icon purple">
      <i class="bi bi-router-fill"></i>
    </div>
    <div class="stat-info">
      <span class="stat-value"><%= stats.total %></span>
      <span class="stat-label">Total ONU</span>
    </div>
  </div>

  <div class="glass-card stat-card">
    <div class="stat-icon green">
      <i class="bi bi-cloud-check-fill"></i>
    </div>
    <div class="stat-info">
      <span class="stat-value"><%= stats.online %></span>
      <span class="stat-label">ONU Online</span>
    </div>
  </div>

  <div class="glass-card stat-card">
    <div class="stat-icon red">
      <i class="bi bi-cloud-slash-fill"></i>
    </div>
    <div class="stat-info">
      <span class="stat-value"><%= stats.offline %></span>
      <span class="stat-label">ONU Offline</span>
    </div>
  </div>

  <div class="glass-card stat-card">
    <div class="stat-icon blue">
      <i class="bi bi-activity"></i>
    </div>
    <div class="stat-info">
      <span class="stat-value"><%= stats.avgRxPower %> dBm</span>
      <span class="stat-label">Rata-rata Rx Power</span>
    </div>
  </div>
</div>



<!-- Charts and Faults Grid -->
<div class="dashboard-grid fade-in">
  <!-- Charts Column -->
  <div class="glass-card" style="display: flex; flex-direction: column; gap: 30px;">
    <h2 style="font-size: 18px; font-weight: 600;">Grafik Statistik Jaringan</h2>
    
    <div class="dashboard-charts-grid">
      <div>
        <h3 style="font-size: 13px; color: var(--text-secondary); text-align: center; margin-bottom: 15px; font-weight: 500;">Status Konektivitas</h3>
        <div style="max-height: 180px; height: 180px; display: flex; justify-content: center; position: relative;">
          <canvas id="statusChart"></canvas>
        </div>
      </div>
      
      <div>
        <h3 style="font-size: 13px; color: var(--text-secondary); text-align: center; margin-bottom: 15px; font-weight: 500;">Rentang Keaktifan Perangkat</h3>
        <div style="max-height: 180px; height: 180px; display: flex; justify-content: center; position: relative;">
          <canvas id="activityChart"></canvas>
        </div>
      </div>
      
      <div>
        <h3 style="font-size: 13px; color: var(--text-secondary); text-align: center; margin-bottom: 15px; font-weight: 500;">Distribusi Vendor ONU</h3>
        <div style="max-height: 180px; height: 180px; display: flex; justify-content: center; position: relative;">
          <canvas id="vendorChart"></canvas>
        </div>
      </div>

      <div>
        <h3 style="font-size: 13px; color: var(--text-secondary); text-align: center; margin-bottom: 15px; font-weight: 500;">Tipe / Model ONU</h3>
        <div style="max-height: 180px; height: 180px; display: flex; justify-content: center; position: relative;">
          <canvas id="modelChart"></canvas>
        </div>
      </div>
    </div>
  </div>

  <!-- Faults Column -->
  <div class="glass-card" style="display: flex; flex-direction: column;">
    <h2 style="font-size: 18px; font-weight: 600; margin-bottom: 20px;">Fault Perangkat Terbaru</h2>
    
    <% if (recentFaults.length === 0) { %>
      <div style="text-align: center; color: var(--text-secondary); padding: 40px 0; flex: 1; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 10px;">
        <i class="bi bi-check-circle" style="font-size: 36px; color: var(--color-success);"></i>
        <span>Semua perangkat berjalan normal tanpa gangguan.</span>
      </div>
    <% } else { %>
      <div style="display: flex; flex-direction: column; gap: 12px; overflow-y: auto; max-height: 280px; padding-right: 5px;">
        <% for (const fault of recentFaults) { %>
          <div style="background: rgba(255, 255, 255, 0.03); border: 1px solid var(--glass-border); border-radius: var(--border-radius-md); padding: 12px 16px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
              <span style="font-weight: 600; font-size: 13px; color: var(--color-danger);"><%= fault.fault_code %></span>
              <span style="font-size: 11px; color: var(--text-secondary);"><%= fault.last_seen %></span>
            </div>
            <p style="font-size: 13px; margin-bottom: 4px; line-height: 1.4;"><%= fault.fault_string %></p>
            <div style="display: flex; justify-content: space-between; align-items: center; font-size: 11px; color: var(--text-secondary); border-top: 1px dashed rgba(255, 255, 255, 0.05); padding-top: 6px; margin-top: 6px;">
              <span>SN: <strong><%= fault.serial_number %></strong></span>
              <a href="/admin/devices/<%= fault.device_id %>" style="color: var(--color-primary); text-decoration: none;">Detail ONU <i class="bi bi-arrow-right"></i></a>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>
</div>

<!-- Render Scripts -->
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const rawData = <%- JSON.stringify(chartData) %>;
    
    // 1. Status Chart (Doughnut)
    const ctxStatus = document.getElementById('statusChart').getContext('2d');
    new Chart(ctxStatus, {
      type: 'doughnut',
      data: {
        labels: ['Online', 'Offline'],
        datasets: [{
          data: rawData.onlineOffline,
          backgroundColor: ['#10b981', '#ef4444'],
          borderColor: '#111827',
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { color: '#f3f4f6', boxWidth: 10, font: { size: 10 } }
          }
        }
      }
    });

    // 2. Activity Chart (PolarArea)
    const ctxActivity = document.getElementById('activityChart').getContext('2d');
    new Chart(ctxActivity, {
      type: 'polarArea',
      data: {
        labels: ['< 10 Menit', '10m - 1 Jam', '1j - 24 Jam', '> 24 Jam'],
        datasets: [{
          data: rawData.activity,
          backgroundColor: ['rgba(16, 185, 129, 0.6)', 'rgba(6, 182, 212, 0.6)', 'rgba(245, 158, 11, 0.6)', 'rgba(239, 68, 68, 0.6)'],
          borderColor: '#111827',
          borderWidth: 1
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          r: {
            grid: { color: 'rgba(255, 255, 255, 0.05)' },
            angleLines: { color: 'rgba(255, 255, 255, 0.05)' },
            ticks: { display: false }
          }
        },
        plugins: {
          legend: {
            position: 'bottom',
            labels: { color: '#f3f4f6', boxWidth: 10, font: { size: 10 } }
          }
        }
      }
    });

    // 3. Vendor Chart (Pie)
    const ctxVendor = document.getElementById('vendorChart').getContext('2d');
    new Chart(ctxVendor, {
      type: 'pie',
      data: {
        labels: rawData.vendors.labels,
        datasets: [{
          data: rawData.vendors.values,
          backgroundColor: ['#6366f1', '#06b6d4', '#f59e0b', '#3b82f6', '#ec4899', '#8b5cf6'],
          borderColor: '#111827',
          borderWidth: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { color: '#f3f4f6', boxWidth: 10, font: { size: 10 } }
          }
        }
      }
    });

    // 4. Model Chart (Bar)
    const ctxModel = document.getElementById('modelChart').getContext('2d');
    new Chart(ctxModel, {
      type: 'bar',
      data: {
        labels: rawData.models.labels,
        datasets: [{
          label: 'Jumlah ONU',
          data: rawData.models.values,
          backgroundColor: '#6366f1',
          borderColor: '#4f46e5',
          borderWidth: 1,
          borderRadius: 4
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          y: {
            grid: { color: 'rgba(255, 255, 255, 0.05)' },
            ticks: { color: '#9ca3af', font: { size: 10 }, stepSize: 1 }
          },
          x: {
            grid: { display: false },
            ticks: { color: '#9ca3af', font: { size: 10 } }
          }
        },
        plugins: {
          legend: { display: false }
        }
      }
    });
  });
</script>

<%- include('../partials/footer') %>
